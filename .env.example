NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3001

# Optional single-string Postgres connection (recommended for AWS Elastic Beanstalk/App Runner with RDS)
DATABASE_URL=

# Public API base URL (used by Swagger UI — optional, defaults to http://localhost:PORT/api)
API_URL=http://localhost:3001/api

# Use these DB_* variables when DATABASE_URL is not provided
DB_HOST=localhost
DB_PORT=5432
DB_NAME=merchant_management_system
DB_USER=postgres
DB_PASSWORD=your_postgres_password

JWT_ACCESS_SECRET=replace_with_access_secret
JWT_REFRESH_SECRET=replace_with_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_INTERVAL_SECONDS=60
WEBHOOK_WORKER_INTERVAL_MS=30000
WEBHOOK_SECRET=replace_with_global_webhook_secret
