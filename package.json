{
  "name": "fintech-merchant-api",
  "version": "1.0.0",
  "description": "Production-grade REST API for merchant onboarding, KYB verification, and webhook event delivery",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "build": "node -e \"console.log('No build step required for Node.js runtime')\"",
    "start": "node src/server.js",
    "test": "cross-env NODE_ENV=test jest --runInBand",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage --runInBand",
    "migrate": "node scripts/runMigrations.js",
    "seed": "node scripts/seedAdmin.js",
    "worker:webhooks": "node src/workers/webhook.worker.js"
  },
  "keywords": [],
  "author": "Bharat Navratna",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
